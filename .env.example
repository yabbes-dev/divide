# Google Gemini API key (server-side only — never expose to the client)
GEMINI_API_KEY=your_gemini_api_key_here

# Legacy alias (also supported)
# GOOGLE_API_KEY=your_gemini_api_key_here

# Optional: override the default Gemini model
# Recommended models (if one is busy, the API auto-tries others):
#   gemini-2.5-flash       (try this if flash-lite is overloaded)
#   gemini-2.5-flash-lite  (cheapest)
GEMINI_MODEL=gemini-2.5-flash
