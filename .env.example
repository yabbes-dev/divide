# Google Gemini API key (server-side only — never expose to the client)
GEMINI_API_KEY=your_gemini_api_key_here

# Legacy alias (also supported)
# GOOGLE_API_KEY=your_gemini_api_key_here

# Optional: Groq fallback when Gemini quotas are exhausted (console.groq.com → API Keys)
# GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.2-11b-vision-preview
# AI_FALLBACK_ENABLED=true

# Optional: override the first Gemini model tried (others auto-fallback on quota limits)
# Default chain: 3.5 Flash → 3 Flash → 3.1 Flash-Lite → 2.5 Flash → 2.5 Flash-Lite
# GEMINI_MODEL=gemini-3.5-flash
