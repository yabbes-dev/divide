# Google Gemini API key (server-side only — never expose to the client)
GEMINI_API_KEY=your_gemini_api_key_here

# Legacy alias (also supported)
# GOOGLE_API_KEY=your_gemini_api_key_here

# Optional: override the first model tried (others auto-fallback on quota limits)
# Fallback chain includes 2.5 Flash, 3.1 Flash-Lite, 3 Flash, and older Flash models
GEMINI_MODEL=gemini-2.5-flash-lite
